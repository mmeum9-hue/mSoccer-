{
  "entities": {
    "Chat": {
      "title": "Chat",
      "description": "A private or group conversation",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The custom name of the group or chat"
        },
        "type": {
          "type": "string",
          "description": "Type of the conversation (direct or group)",
          "enum": ["direct", "group"]
        },
        "participants": {
          "type": "array",
          "description": "List of user UIDs participating in this chat"
        },
        "joinedAt": {
          "type": "object",
          "description": "Map of user UID to join timestamp"
        },
        "createdBy": {
          "type": "string",
          "description": "The creator of the chat"
        },
        "createdAt": {
          "type": "string",
          "description": "The creation timestamp"
        },
        "lastMessage": {
          "type": "string",
          "description": "The snippet of the last message sent"
        },
        "lastMessageAt": {
          "type": "string",
          "description": "The timestamp of the last message sent"
        }
      },
      "required": ["type", "participants", "createdBy"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single chat message within a conversation",
      "type": "object",
      "properties": {
        "chatId": {
          "type": "string",
          "description": "The ID of the parent Chat"
        },
        "senderId": {
          "type": "string",
          "description": "The user UID of the sender"
        },
        "senderName": {
          "type": "string",
          "description": "Name of the sender"
        },
        "senderTeam": {
          "type": "string",
          "description": "The soccer team of the sender"
        },
        "senderAvatar": {
          "type": "string",
          "description": "URL to the sender avatar"
        },
        "text": {
          "type": "string",
          "description": "The message body"
        },
        "mediaUrl": {
          "type": "string",
          "description": "Optional attached image or video URL"
        },
        "mediaType": {
          "type": "string",
          "description": "The type of attached media"
        },
        "timestamp": {
          "type": "string",
          "description": "Human-readable local time"
        },
        "likes": {
          "type": "number",
          "description": "Number of hearts received"
        },
        "status": {
          "type": "string",
          "description": "Delivery status of the message",
          "enum": ["sent", "delivered", "read"]
        }
      },
      "required": ["chatId", "senderId", "senderName", "text"]
    },
    "UserPresence": {
      "title": "UserPresence",
      "description": "Real-time presence and typing status of a user",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "User unique identifier"
        },
        "name": {
          "type": "string",
          "description": "Display name"
        },
        "photoUrl": {
          "type": "string",
          "description": "Avatar URL"
        },
        "status": {
          "type": "string",
          "description": "Whether the user is online or offline",
          "enum": ["online", "offline"]
        },
        "typingIn": {
          "type": "string",
          "description": "The chat room ID the user is currently typing in, or null"
        }
      },
      "required": ["uid", "name", "status"]
    }
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Store all conversations/chats"
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Store all chat messages"
    },
    "/user_presence/{userId}": {
      "schema": "UserPresence",
      "description": "Store real-time online status and typing activity"
    }
  }
}
