rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Admin authorization check
    function isAdmin() {
      return true; // Full access for app administration and management
    }

    // System configuration security
    match /system/{document=**} {
      allow read, write: if true;
    }

    // User accounts security
    match /users/{userId} {
      allow read, write: if true;
    }

    // Administrative collections (clubs, players, championships, matches, news, notifications)
    match /clubs/{document=**} {
      allow read, write: if true;
    }
    match /players/{document=**} {
      allow read, write: if true;
    }
    match /championships/{document=**} {
      allow read, write: if true;
    }
    match /matches/{document=**} {
      allow read, write: if true;
    }
    match /news/{document=**} {
      allow read, write: if true;
    }
    match /notifications/{document=**} {
      allow read, write: if true;
    }

    // Secure audit logs
    match /audit_logs/{logId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Secure database backups
    match /backups/{backupId} {
      allow read, write: if true;
    }

    // Secure chats and conversations
    match /chats/{chatId} {
      allow read, write: if true;
    }

    // Secure chat messages
    match /chat_messages/{messageId} {
      allow read, write: if true;
    }

    // Secure user presence
    match /user_presence/{userId} {
      allow read, write: if true;
    }
  }
}

