rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Default catch-all for other collections (read/write is allowed for public demo state)
    match /system/{document=**} {
      allow read, write: if true;
    }
    match /users/{document=**} {
      allow read, write: if true;
    }
    match /clubs/{document=**} {
      allow read, write: if true;
    }
    match /players/{document=**} {
      allow read, write: if true;
    }
    match /championships/{document=**} {
      allow read, write: if true;
    }
    match /matches/{document=**} {
      allow read, write: if true;
    }
    match /news/{document=**} {
      allow read, write: if true;
    }
    match /notifications/{document=**} {
      allow read, write: if true;
    }

    // Harden chat messages
    match /chat_messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && request.resource.data.senderName is string 
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow update: if isSignedIn();
      allow delete: if false; // Messages cannot be deleted by users
    }

    // Harden user presence
    match /user_presence/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}
